# ============================================================
# Oppi — Environment Variables
# Copy to .env and fill in real values before running locally
# NEVER commit .env to git
# ============================================================

# Auth Service
DATABASE_URL=postgresql://oppi:password@localhost:5432/auth_db
JWT_ACCESS_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production-different

# PostgreSQL (used by docker-compose)
POSTGRES_PASSWORD=password

# AWS (local dev via LocalStack)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# LocalStack Pro (optional — leave empty for community edition)
LOCALSTACK_AUTH_TOKEN=

# CORS (comma-separated origins, * for dev)
CORS_ORIGIN=http://localhost:3000,http://localhost:19006
